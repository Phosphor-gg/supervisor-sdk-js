{
  "name": "supervisor-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for the Supervisor content moderation API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "moderation",
    "content-moderation",
    "ai",
    "safety",
    "supervisor"
  ],
  "author": "Phosphor Technologies",
  "license": "MIT",
  "homepage": "https://supervisor.gg",
  "repository": {
    "type": "git",
    "url": "https://github.com/phosphor-tech/supervisor-sdk-js"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.0"
  }
}
